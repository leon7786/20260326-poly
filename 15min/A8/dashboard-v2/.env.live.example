# Polymarket live trading env example
# 复制为 .env.live 后填写。不要把真实密钥提交到 GitHub。

# signer private key（留空）
POLYMARKET_PRIVATE_KEY=

# Polymarket developer API key（留空）
POLYMARKET_API_KEY=

# 可选：Relayer API key（留空）
POLYMARKET_RELAYER_API_KEY=

# Polygon chain id
POLYMARKET_CHAIN_ID=137

# signer 地址（留空）
POLYMARKET_WALLET_ADDRESS=

# funder / profile / proxy 地址（留空）
POLYMARKET_FUNDER_ADDRESS=

# Live 开关
LIVE_ENABLED=false
DRY_RUN=true

# 风控默认值
LIVE_BUDGET_USDC=10
MAX_ORDER_USDC=1
MAX_CONCURRENT_POSITIONS=1
ALLOWED_COINS=BTC,ETH,SOL
MAX_BUY_PRICE=0.30
MAX_DAILY_LOSS_USDC=2
ORDER_MODE=maker
ORDER_TIMEOUT_SECONDS=20
SYNC_INTERVAL_SECONDS=5
