# Polymarket live trading env example
# 复制为 .env.live 后填写。不要把真实密钥提交到 GitHub。

# signer private key（示例占位符）
POLYMARKET_PRIVATE_KEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Polymarket developer API key（示例占位符）
POLYMARKET_API_KEY=pk-xxxxxxxxxxxxxxxx

# 可选：Relayer API key（示例占位符）
POLYMARKET_RELAYER_API_KEY=rk-xxxxxxxxxxxxxxxx

# Polygon chain id
POLYMARKET_CHAIN_ID=137

# signer 地址（示例占位符）
POLYMARKET_WALLET_ADDRESS=0x1111111111111111111111111111111111111111

# funder / profile / proxy 地址（示例占位符）
POLYMARKET_FUNDER_ADDRESS=0x2222222222222222222222222222222222222222

# Live 开关
LIVE_ENABLED=false
DRY_RUN=true

# 风控默认值
LIVE_BUDGET_USDC=10
MAX_ORDER_USDC=1
MAX_CONCURRENT_POSITIONS=1
ALLOWED_COINS=BTC,ETH,SOL
MAX_BUY_PRICE=0.30
MAX_DAILY_LOSS_USDC=2
ORDER_MODE=market
ORDER_TIMEOUT_SECONDS=45
SYNC_INTERVAL_SECONDS=5
LIVE_FAST_POLL_INTERVAL=0.2
LIVE_SLOW_POLL_INTERVAL=1.5
MIN_ORDER_SIZE=5
REPRICE_ON_TIMEOUT=true
MAX_REPRICE_STEPS=1
