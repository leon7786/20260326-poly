[Unit]
Description=Polymarket Paper Trader v3.1
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/projects/polymarket-arb/src
ExecStart=/usr/bin/python3 -u paper_trader_v3.py
StandardOutput=append:/root/projects/polymarket-arb/output/paper_trader.log
StandardError=append:/root/projects/polymarket-arb/output/paper_trader.log
Restart=always
RestartSec=10
WatchdogSec=300

[Install]
WantedBy=default.target
