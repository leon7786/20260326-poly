[Unit]
Description=Polymarket Dashboard (port 5011)
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/projects/polymarket-arb/src
ExecStart=/root/projects/polymarket-arb/venv/bin/python3 -u dashboard.py
StandardOutput=append:/root/projects/polymarket-arb/output/dashboard.log
StandardError=append:/root/projects/polymarket-arb/output/dashboard.log
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
